/* ============ 全局设计令牌（§6.8 现代简约）============ */
page {
  --bg: #F5F6F8;
  --card: #FFFFFF;
  --line: rgba(0, 0, 0, 0.06);
  --brand: #0D9488;        /* 品牌青绿（与 PC 端统一） */
  --red: #FA5151;
  --green: #1FB673;
  --orange: #FF8F1F;
  --yellow: #FFB400;
  --blue: #3B82F6;         /* 语义蓝（info），区别于品牌色 */
  --text: #1A1A1A;
  --text-2: #6B7178;
  --text-3: #9AA0A6;
  --fill: #F2F3F5;        /* 浅灰填充：chip、空态、弱背景 */
  --fill-2: #F7F8FA;      /* 输入框/说明块底 */
  --brand-weak: rgba(13,148,136,0.08);   /* 品牌浅底 */
  --brand-line: rgba(13,148,136,0.30);    /* 品牌描边 */
  --disabled: #B0B4B9;     /* 禁用态灰 */
  background: var(--bg);
  color: var(--text);
  font-size: 26rpx;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 400;
  -webkit-font-smoothing: antialiased;
}

view, text, button, input { box-sizing: border-box; }

/* 卡片：纯白、24rpx 圆角、0.5px 极细边框、零阴影零渐变 */
.card {
  background: var(--card);
  border-radius: 24rpx;
  border: 1rpx solid var(--line);
  padding: 28rpx;
}

/* 细线分隔 */
.hairline { height: 1rpx; background: var(--line); }

/* 区块标题 */
.section { margin: 36rpx 24rpx 12rpx; }
.section-title {
  font-size: 30rpx; font-weight: 600; color: var(--text);
  display: flex; align-items: center; justify-content: space-between;
}
.section-more { font-size: 24rpx; color: var(--text-3); font-weight: 400; }

/* 主操作按钮：品牌青绿，无渐变无阴影 */
.btn-primary {
  display: flex; align-items: center; justify-content: center; padding: 0;
  background: var(--brand); color: #FFFFFF; border-radius: 16rpx;
  font-size: 30rpx; font-weight: 500; height: 88rpx;
  border: none;
}
.btn-primary::after { border: none; }
.btn-primary[disabled] { background: var(--disabled); color: #FFFFFF; }
.btn-ghost {
  display: flex; align-items: center; justify-content: center; padding: 0;
  background: #FFFFFF; color: var(--text-2); border-radius: 16rpx;
  font-size: 28rpx; height: 80rpx;
  border: 1rpx solid var(--line);
}
.btn-ghost::after { border: none; }
.btn-warn {
  display: flex; align-items: center; justify-content: center; padding: 0;
  background: rgba(255,143,31,0.12); color: var(--orange); border-radius: 16rpx;
  font-size: 30rpx; font-weight: 500; height: 88rpx;
  border: 1rpx solid rgba(255,143,31,0.4);
}
.btn-warn::after { border: none; }
.btn-sm { height: 60rpx; line-height: 60rpx; font-size: 24rpx; border-radius: 12rpx; display: inline-flex; align-items: center; justify-content: center; padding: 0 28rpx; }

/* 状态点 */
.dot { width: 12rpx; height: 12rpx; border-radius: 50%; display: inline-block; }
.dot-red { background: var(--red); }
.dot-green { background: var(--green); }
.dot-orange { background: var(--orange); }
.dot-yellow { background: var(--yellow); }
.dot-blue { background: var(--blue); }
.dot-gray { background: var(--text-3); }

/* 通用标签 */
.tag {
  font-size: 22rpx; color: var(--text-2); background: var(--fill);
  border-radius: 8rpx; padding: 4rpx 14rpx; font-weight: 400;
}
.tag-red { color: var(--red); background: rgba(250,81,81,0.08); }
.tag-green { color: var(--green); background: rgba(31,182,115,0.10); }
.tag-orange { color: var(--orange); background: rgba(255,143,31,0.10); }
.tag-yellow { color: var(--yellow); background: rgba(255,180,0,0.12); }
.tag-blue { color: var(--blue); background: rgba(59,130,246,0.08); }
.tag-brand { color: var(--brand); background: rgba(13,148,136,0.08); }

/* 空态 */
.empty { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-circle { width: 120rpx; height: 120rpx; border-radius: 50%; background: var(--fill); color: #C9CCD1; font-size: 40rpx; text-align: center; line-height: 120rpx; }
.empty-tx { font-size: 24rpx; color: var(--text-3); margin-top: 16rpx; }

/* 底部弹层（行动/详情）*/
.sheet-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.45); z-index: 50;
}
.sheet {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 51;
  background: #FFFFFF; border-radius: 28rpx 28rpx 0 0;
  padding: 36rpx 28rpx calc(36rpx + env(safe-area-inset-bottom));
  max-height: 84vh; overflow-y: auto;
}
.sheet-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.sheet-title { font-size: 32rpx; font-weight: 500; }
.sheet-close { font-size: 44rpx; color: var(--text-3); line-height: 1; padding: 0 8rpx; }

/* 弱网同步条 */
.sync-bar {
  background: rgba(255,143,31,0.10); color: var(--orange);
  font-size: 24rpx; padding: 16rpx 24rpx; text-align: center;
}
