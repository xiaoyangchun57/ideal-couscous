.topbar { display: flex; justify-content: flex-end; padding: 20rpx 24rpx 0; }
.tb-btn { font-size: 26rpx; color: var(--text-2); padding: 10rpx 28rpx; border-radius: 999rpx; border: 1rpx solid var(--line); margin-left: 16rpx; }
.tb-brand { color: var(--brand); border-color: var(--brand-line); }

.list-card { margin: 16rpx 24rpx 0; padding: 8rpx 28rpx; }
.row { display: flex; align-items: flex-start; padding: 26rpx 0; border-bottom: 1rpx solid var(--line); }
.row:last-child { border-bottom: none; }
.row-unread { background: var(--brand-weak); }
.row-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: var(--brand); margin-top: 14rpx; margin-right: 16rpx; flex-shrink: 0; }
.row-main { flex: 1; min-width: 0; }
.row-title { font-size: 28rpx; color: var(--text); display: block; }
.row-sub { font-size: 24rpx; color: var(--text-2); margin-top: 8rpx; display: block; line-height: 1.5; }
.row-time { font-size: 22rpx; color: var(--text-3); margin-top: 10rpx; display: block; }
