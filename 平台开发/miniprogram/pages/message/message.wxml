<view class="page">
  <view class="topbar">
    <view class="tb-btn" bindtap="onReadAll">全部已读</view>
    <view class="tb-btn tb-brand" bindtap="onSubscribe">订阅消息</view>
  </view>

  <view class="card list-card" wx:if="{{list.length}}">
    <view class="row {{item.is_read ? '' : 'row-unread'}}" wx:for="{{list}}" wx:key="id" bindtap="onTap" data-id="{{item.id}}">
      <view class="row-dot" wx:if="{{!item.is_read}}"></view>
      <view class="row-main">
        <text class="row-title">{{item.title}}</text>
        <text class="row-sub">{{item.content}}</text>
        <text class="row-time">{{item.time}}</text>
      </view>
    </view>
  </view>
  <view class="empty" wx:elif="{{loaded}}">
    <view class="empty-circle"></view>
    <text class="empty-tx">暂无消息</text>
  </view>

  <view class="list-foot" wx:if="{{list.length && !noMore}}">上拉加载更多</view>
  <view class="list-foot" wx:if="{{noMore}}">没有更多了</view>
</view>
